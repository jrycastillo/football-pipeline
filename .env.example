# Football Pipeline Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
MYSQL_HOST=your-database-host.ondigitalocean.com
MYSQL_PORT=25060
MYSQL_USER=scoutbridge
MYSQL_PASSWORD=your-secure-password-here
MYSQL_DB=footballgallery
TABLE_NAME=MatchesVideoAnalysis_test

# ScoutBridge API
SBG_BASE=https://api-staging.scoutbridge.net/football-gallery/api
SBG_TOKEN=your-jwt-token-here

# Video Processing (Optional - Override config.yaml)
# SRC_VIDEO=test_videos/your_video.mp4
# DET_WEIGHTS=models/yolo_player.pt
# POSE_WEIGHTS=models/yolo_pitch.pt
# JNR_WEIGHTS=models/resnet34_rgb_jnr.pt
# BALL_MODEL_PATH=models/yolo_ball.pt

# Processing Limits (Optional)
# MAX_TRACK_FRAMES=3000
# VID_STRIDE=1
# DET_IMG_SIZE=832

# Output Paths (Optional)
# OUT_JSON=players_stats.json
# OUT_CSV=players_stats.csv
